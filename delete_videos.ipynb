    "from pathlib import Path\n",
    "import os\n",
    "\n",
    "video_name = 'vid.avi'\n",
    "parent_dir = Path(os.path.join('data','UBFC-RPPG-Dataset'))\n",
    "\n",
    "for video_path in parent_dir.rglob(video_name):\n",
    "    if video_path.is_file():\n",
    "        video_path.unlink()\n",
    "        print(f\"Deleted: {video_path}\")"
   ]
